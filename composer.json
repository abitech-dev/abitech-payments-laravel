{
    "name": "abitech/payments-laravel",
    "description": "Motor de pasarelas de pago para aplicaciones Laravel.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/cache": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "suggest": {
        "mercadopago/dx-php": "Requerido para usar los drivers de Mercado Pago (^3.0)",
        "stripe/stripe-php": "Requerido para usar los drivers de Stripe (^15.0+)"
    },
    "autoload": {
        "psr-4": {
            "Abitech\\Payments\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Abitech\\Payments\\Providers\\PaymentsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
